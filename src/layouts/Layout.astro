---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "seldas | Research Updates", 
	description = "Personal research updates, notes, and technical tracking for projects under github.com/seldas (LabelComp, HetEnc_Code)." 
} = Astro.props;

// Determine current active link
const pathname = new URL(Astro.request.url).pathname;
const isHome = pathname === '/' || pathname === '';
const isProjects = pathname.startsWith('/projects');
const isUpdates = pathname.startsWith('/updates');
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />

		<!-- Fonts pre-load -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	</head>
	<body>
		<!-- Top Header / Navigation -->
		<header class="header">
			<div class="container nav-container">
				<a href="/" class="logo">
					<span class="logo-name">SELDAS</span>
					<span class="logo-sub">Bioinformatics & NLP Research</span>
				</a>
				<nav class="nav">
					<a href="/" class={isHome ? "active" : ""}>Home</a>
					<span class="nav-sep">/</span>
					<a href="/projects" class={isProjects ? "active" : ""}>Projects</a>
					<span class="nav-sep">/</span>
					<a href="/updates" class={isUpdates ? "active" : ""}>Updates</a>
					<span class="nav-sep">/</span>
					<a href="https://github.com/seldas" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="GitHub Profile">GitHub</a>
				</nav>
			</div>
		</header>

		<!-- Main Content Slot -->
		<main class="main-content">
			<slot />
		</main>

		<!-- Footer -->
		<footer class="footer">
			<div class="container footer-content">
				<p>© {new Date().getFullYear()} seldas. Built with Astro.</p>
				<div class="footer-links">
					<a href="https://github.com/seldas" target="_blank" rel="noopener noreferrer">GitHub</a>
					<span class="sep">•</span>
					<a href="https://github.com/seldas/LabelComp" target="_blank" rel="noopener noreferrer">LabelComp</a>
					<span class="sep">•</span>
					<a href="https://github.com/seldas/HetEnc_Code" target="_blank" rel="noopener noreferrer">HetEnc</a>
				</div>
			</div>
		</footer>
	</body>
</html>

<style>
	/* Header Navigation */
	.header {
		padding: 2.5rem 0 1.5rem;
		background: none;
		border-bottom: 1px solid var(--border-color);
	}
	.nav-container {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}
	@media (min-width: 640px) {
		.nav-container {
			flex-direction: row;
			align-items: flex-end;
			justify-content: space-between;
		}
	}
	.logo {
		text-decoration: none;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}
	.logo-name {
		font-family: var(--font-sans);
		font-size: 1.4rem;
		font-weight: 700;
		letter-spacing: 0.05em;
		color: var(--text-primary);
		line-height: 1.1;
	}
	.logo-sub {
		font-family: var(--font-sans);
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-muted);
		font-weight: 600;
	}
	.nav {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.75rem;
		font-family: var(--font-sans);
		font-size: 0.9rem;
	}
	.nav a {
		color: var(--text-secondary);
		text-decoration: none;
		font-weight: 500;
		padding: 0.1rem 0;
	}
	.nav a:hover, .nav a.active {
		color: var(--accent-color);
		text-decoration: underline;
		text-decoration-thickness: 1.5px;
		text-underline-offset: 4px;
	}
	.nav-sep {
		color: #d1d5db;
		user-select: none;
		font-size: 0.85rem;
	}
	.social-link {
		color: var(--text-secondary);
	}

	/* Main Area */
	.main-content {
		min-height: calc(100vh - var(--nav-height) - 160px);
		padding: 2.5rem 0;
	}

	/* Footer */
	.footer {
		border-top: 1px solid var(--border-color);
		background: #fafafa;
		padding: 2rem 0;
		font-family: var(--font-sans);
		font-size: 0.85rem;
		color: var(--text-muted);
	}
	.footer-content {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.75rem;
		text-align: center;
	}
	@media (min-width: 640px) {
		.footer-content {
			flex-direction: row;
			justify-content: space-between;
			text-align: left;
		}
	}
	.footer-links {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}
	.footer-links a {
		color: var(--text-muted);
		text-decoration: none;
	}
	.footer-links a:hover {
		color: var(--accent-color);
		text-decoration: underline;
	}
	.sep {
		opacity: 0.3;
	}
</style>
