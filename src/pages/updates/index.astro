---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

const rawUpdates = await getCollection('updates');
const updates = await Promise.all(
	rawUpdates.map(async (up) => {
		const { Content } = await render(up);
		return {
			id: up.id,
			data: up.data,
			Content
		};
	})
);

// Helper to get YYYY-MM-DD in UTC
function getUTCDateString(date: Date) {
	const y = date.getUTCFullYear();
	const m = String(date.getUTCMonth() + 1).padStart(2, '0');
	const d = String(date.getUTCDate()).padStart(2, '0');
	return `${y}-${m}-${d}`;
}

interface CalendarDay {
	dayNumber: number | null;
	dateStr: string | null;
	isCurrentMonth: boolean;
	updates: typeof updates;
}

interface CalendarWeek {
	weekLabel: string;
	days: CalendarDay[];
	hasUpdates: boolean;
	weekUpdates: typeof updates;
	weekId: string;
}

interface MonthData {
	name: string;
	year: number;
	monthIndex: number; // 0-indexed: 2 = March, 3 = April, 4 = May
	days: CalendarDay[];
	weeks: CalendarWeek[];
	allUpdates: typeof updates;
}

function getMonthDays(year: number, monthIndex: number, updatesList: typeof updates): CalendarDay[] {
	const days: CalendarDay[] = [];
	
	// Day of the week for the 1st of the month (0 = Sun, 1 = Mon, ..., 6 = Sat)
	const firstDayOfWeek = new Date(year, monthIndex, 1).getDay();
	
	// Total days in the month
	const totalDays = new Date(year, monthIndex + 1, 0).getDate();
	
	// Padding days at start
	for (let i = 0; i < firstDayOfWeek; i++) {
		days.push({
			dayNumber: null,
			dateStr: null,
			isCurrentMonth: false,
			updates: []
		});
	}
	
	// Current month days
	for (let day = 1; day <= totalDays; day++) {
		const currentDateStr = `${year}-${String(monthIndex + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
		const dayUpdates = updatesList.filter(update => {
			return getUTCDateString(update.data.date) === currentDateStr;
		});
		
		days.push({
			dayNumber: day,
			dateStr: currentDateStr,
			isCurrentMonth: true,
			updates: dayUpdates
		});
	}
	
	// Padding days at end to fill the grid (multiple of 7)
	const totalCells = Math.ceil(days.length / 7) * 7;
	const paddingEnd = totalCells - days.length;
	for (let i = 0; i < paddingEnd; i++) {
		days.push({
			dayNumber: null,
			dateStr: null,
			isCurrentMonth: false,
			updates: []
		});
	}
	
	return days;
}

function getMonthWeeks(monthDays: CalendarDay[], monthName: string, year: number): CalendarWeek[] {
	const weeks: CalendarWeek[] = [];
	for (let i = 0; i < monthDays.length; i += 7) {
		const weekDays = monthDays.slice(i, i + 7);
		
		// Find first and last valid day numbers
		const validDays = weekDays.filter(d => d.dayNumber !== null);
		if (validDays.length === 0) continue;
		
		const firstDay = validDays[0].dayNumber!;
		const lastDay = validDays[validDays.length - 1].dayNumber!;
		const weekLabel = `${monthName} ${firstDay} – ${lastDay}`;
		
		// Gather all updates in this week
		const weekUpdates: typeof updates = [];
		weekDays.forEach(d => {
			if (d.updates && d.updates.length > 0) {
				weekUpdates.push(...d.updates);
			}
		});
		
		// Sort week updates chronologically descending
		weekUpdates.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
		
		weeks.push({
			weekLabel,
			days: weekDays,
			hasUpdates: weekUpdates.length > 0,
			weekUpdates,
			weekId: `${year}-${monthName.toLowerCase()}-w${Math.floor(i / 7) + 1}`
		});
	}
	return weeks;
}

// Get all updates for a specific month
function getMonthUpdates(monthIndex: number, year: number, updatesList: typeof updates) {
	return updatesList.filter(update => {
		const d = update.data.date;
		return d.getUTCFullYear() === year && d.getUTCMonth() === monthIndex;
	}).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
}

function getUpdateWeekId(updateDate: Date, weeks: CalendarWeek[]): string {
	const dateStr = getUTCDateString(updateDate);
	const foundWeek = weeks.find(w => w.days.some(d => d.dateStr === dateStr));
	return foundWeek ? foundWeek.weekId : '';
}

const monthNames = [
	"January", "February", "March", "April", "May", "June",
	"July", "August", "September", "October", "November", "December"
];

// Dynamically generate the months list based on the updates collection
const uniqueMonths = new Map<string, { year: number; monthIndex: number }>();

// Add the current month to ensure it is always visible even if there are no updates yet
const now = new Date();
const currentKey = `${now.getUTCFullYear()}-${now.getUTCMonth()}`;
uniqueMonths.set(currentKey, { year: now.getUTCFullYear(), monthIndex: now.getUTCMonth() });

// Gather other months from actual updates
updates.forEach(update => {
	const d = update.data.date;
	const key = `${d.getUTCFullYear()}-${d.getUTCMonth()}`;
	if (!uniqueMonths.has(key)) {
		uniqueMonths.set(key, { year: d.getUTCFullYear(), monthIndex: d.getUTCMonth() });
	}
});

// Sort months chronologically descending
const sortedMonthKeys = Array.from(uniqueMonths.keys()).sort((a, b) => {
	const [yA, mA] = a.split('-').map(Number);
	const [yB, mB] = b.split('-').map(Number);
	if (yA !== yB) return yB - yA;
	return mB - mA;
});

const calendarMonths: MonthData[] = sortedMonthKeys.map(key => {
	const { year, monthIndex } = uniqueMonths.get(key)!;
	const name = monthNames[monthIndex];
	const days = getMonthDays(year, monthIndex, updates);
	return {
		name,
		year,
		monthIndex,
		days,
		weeks: getMonthWeeks(days, name, year),
		allUpdates: getMonthUpdates(monthIndex, year, updates)
	};
});

const projectMeta: Record<string, { label: string; class: string; bg: string; color: string; border: string; dotColor: string }> = {
	'askfdalabel': { label: 'AskFDALabel', class: 'proj-askfdalabel', bg: '#eff6ff', color: '#1e40af', border: '#bfdbfe', dotColor: '#3b82f6' },
	'askmyfaers': { label: 'AskMyFAERS', class: 'proj-askmyfaers', bg: '#f5f3ff', color: '#4f46e5', border: '#ddd6fe', dotColor: '#6366f1' },
	'llm4ae': { label: 'LLM4AE', class: 'proj-llm4ae', bg: '#ecfdf5', color: '#047857', border: '#a7f3d0', dotColor: '#10b981' },
	'ganomics': { label: 'GANomics', class: 'proj-ganomics', bg: '#fffbeb', color: '#b45309', border: '#fde68a', dotColor: '#f59e0b' },
	'dbbtoolkits': { label: 'DBBToolkits', class: 'proj-dbbtoolkits', bg: '#fff1f2', color: '#e11d48', border: '#fecdd3', dotColor: '#f43f5e' },
	'labelcomp': { label: 'LabelComp', class: 'proj-labelcomp', bg: '#f3f4f6', color: '#4b5563', border: '#e5e7eb', dotColor: '#9ca3af' },
	'hetenc': { label: 'HetEnc', class: 'proj-hetenc', bg: '#f0fdfa', color: '#0d9488', border: '#ccfbf1', dotColor: '#14b8a6' }
};

function getProjectMeta(proj: string | undefined) {
	const key = (proj || '').toLowerCase().trim();
	return projectMeta[key] || { label: proj || 'Update', class: 'proj-generic', bg: '#f8fafc', color: '#475569', border: '#e2e8f0', dotColor: '#64748b' };
}

function formatLogDate(date: Date) {
	return date.toLocaleDateString('en-US', {
		weekday: 'long',
		year: 'numeric',
		month: 'long',
		day: 'numeric',
		timeZone: 'UTC'
	});
}
---

<Layout title="Research Calendar | seldas Updates" description="Weekly chronological research activity and commit updates for FDA labeling and pharmacovigilance tools.">
	<div class="container container-wide">
		<header class="page-header">
			<h1 class="page-title">Research Calendar</h1>
			<p class="page-subtitle">A visual record of pipeline developments, experimental commits, and model releases across active repositories.</p>
		</header>

		<!-- Project Legend -->
		<div class="legend-container">
			<span class="legend-title">Repository Key:</span>
			<div class="legend-items">
				{Object.entries(projectMeta).map(([key, meta]) => (
					<div class="legend-item" key={key}>
						<span class="legend-dot" style={`background-color: ${meta.dotColor};`}></span>
						<span class="legend-label">{meta.label}</span>
					</div>
				))}
			</div>
		</div>

		<!-- Interactive Controls Banner (Hidden by default, shown by JS) -->
		<div id="filter-banner" class="filter-banner" style="display: none;">
			<div class="filter-banner-content">
				<span class="filter-banner-text">Showing updates for <strong id="filter-date-display"></strong>.</span>
				<button id="clear-filter-global" class="btn btn-secondary btn-sm">Show All Updates</button>
			</div>
		</div>

		<!-- Calendar Slider Navigation Bar -->
		<div class="calendar-nav-bar">
			<button id="prev-month-btn" class="nav-arrow-btn" aria-label="Previous Month">
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
			</button>
			<div class="nav-month-display">
				<span id="current-month-name">May 2026</span>
			</div>
			<button id="next-month-btn" class="nav-arrow-btn" aria-label="Next Month">
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
			</button>
		</div>

		<!-- Animated Slider Container -->
		<div class="calendar-slider-container">
			{calendarMonths.map((month, index) => (
				<section 
					class={`month-slide ${index === 0 ? 'slide-active' : 'slide-inactive slide-right'}`} 
					id={`month-${month.name.toLowerCase()}`}
					data-slide-index={index}
					data-month-label={`${month.name} ${month.year}`}
				>
					<!-- Week-Basis Calendar Container -->
					<div class="calendar-weeks-container">
						{month.weeks.map((week) => {
							return (
								<div 
									class={`week-row-card ${week.hasUpdates ? 'week-has-updates' : ''}`}
									data-week-id={week.weekId}
									data-month={month.name.toLowerCase()}
									key={week.weekId}
								>
									{/* Left Section: Week Label and Update count */}
									<div class="week-info-section">
										<h4 class="week-label">{week.weekLabel}</h4>
										<span class="week-status">
											{week.weekUpdates.length > 0 
												? `${week.weekUpdates.length} update${week.weekUpdates.length > 1 ? 's' : ''}`
												: 'No updates'
											}
										</span>
										{week.hasUpdates && (
											<button 
												class="btn-filter-week"
												data-week-filter-id={week.weekId}
												data-month={month.name.toLowerCase()}
												title="Filter feed by this week"
											>
												Filter Week
											</button>
										)}
									</div>

									{/* Center Section: Weekdays Day Strip */}
									<div class="week-days-strip">
										{week.days.map((cell, dayIdx) => {
											const weekdayNames = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
											const weekdayName = weekdayNames[dayIdx];
											const hasUpdates = cell.updates.length > 0;
											
											return (
												<div 
													class={`day-chip ${cell.dayNumber === null ? 'day-padding' : ''} ${hasUpdates ? 'day-active' : ''}`}
													data-date={cell.dateStr}
													data-month={month.name.toLowerCase()}
													data-week-id={week.weekId}
													key={cell.dateStr || `padding-${dayIdx}-${Math.random()}`}
													title={cell.dayNumber ? `${weekdayName}, ${month.name} ${cell.dayNumber}${hasUpdates ? ` (${cell.updates.length} updates)` : ''}` : ''}
												>
													<span class="day-name-label">{weekdayName}</span>
													<div class="day-circle">
														{cell.dayNumber && <span class="day-num-text">{cell.dayNumber}</span>}
													</div>
													{hasUpdates && (
														<div class="day-update-dots">
															{cell.updates.map(up => {
																const meta = getProjectMeta(up.data.project);
																return (
																	<span 
																		class="day-dot" 
																		style={`background-color: ${meta.dotColor};`}
																		title={meta.label}
																	></span>
																);
															})}
														</div>
													)}
												</div>
											);
										})}
									</div>

									{/* Right Section: Quick Links to Updates */}
									<div class="week-quick-links">
										{week.weekUpdates.map((update) => {
											const meta = getProjectMeta(update.data.project);
											return (
												<a 
													href={`/updates/${update.id}`} 
													class="quick-update-badge"
													title={update.data.title}
													style={`--badge-bg: ${meta.bg}; --badge-color: ${meta.color}; --badge-border: ${meta.border};`}
													key={update.id}
												>
													<span class="badge-dot" style={`background-color: ${meta.dotColor};`}></span>
													<span class="badge-text">{meta.label}</span>
												</a>
											);
										})}
									</div>
								</div>
							);
						})}
					</div>

					{/* Chronological updates for this month */}
					<div class="month-log-section">
						<div class="month-log-header">
							<h3 class="month-log-title">{month.name} Activity Feed</h3>
							<button class="clear-month-filter-btn" data-month={month.name.toLowerCase()} style="display: none;">
								Reset Filter
							</button>
						</div>
						<div class="month-log-list" data-month-list={month.name.toLowerCase()}>
							{month.allUpdates.length > 0 ? (
								month.allUpdates.map((update) => {
									const meta = getProjectMeta(update.data.project);
									return (
										<article 
											class="update-card" 
											data-card-date={getUTCDateString(update.data.date)}
											data-week-id={getUpdateWeekId(update.data.date, month.weeks)}
											data-update-id={update.id}
											key={update.id}
										>
											<div class="update-card-header-clickable" data-toggle-id={update.id}>
												<div class="update-card-meta-line">
													<time class="update-card-date">{formatLogDate(update.data.date)}</time>
													{update.data.project && (
														<span class="badge badge-update" style={`background-color: ${meta.bg}; color: ${meta.color}; border-color: ${meta.border};`}>
															{meta.label}
														</span>
													)}
												</div>
												<h4 class="update-card-title-row">
													<span class="update-title-text">{update.data.title}</span>
													<span class="expand-arrow-icon">
														<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="arrow-svg"><polyline points="6 9 12 15 18 9"></polyline></svg>
													</span>
												</h4>
												{update.data.description && (
													<p class="update-card-desc">{update.data.description}</p>
												)}
												<div class="update-card-tags-row">
													{update.data.tags.map(tag => (
														<span class="tag-badge" key={tag}>#{tag}</span>
													))}
												</div>
											</div>
											
											<!-- Collapsible Content Panel -->
											<div class="update-card-content-panel" id={`panel-${update.id}`}>
												<div class="panel-inner-content">
													<div class="post-body">
														{(() => { const Content = update.Content; return <Content /> })()}
													</div>
													<div class="panel-footer-actions">
														<a href={`/updates/${update.id}`} class="direct-permalink">
															<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="link-icon"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
															Direct Permalink
														</a>
													</div>
												</div>
											</div>
										</article>
									);
								})
							) : (
								<p class="no-activity">No releases or updates documented this month.</p>
							)}
						</div>
					</div>
				</section>
			))}
		</div>
	</div>
</Layout>

<script>
	// Interactive Calendar & Month Slider Script
	document.addEventListener('DOMContentLoaded', () => {
		const slides = document.querySelectorAll('.month-slide');
		const prevBtn = document.getElementById('prev-month-btn');
		const nextBtn = document.getElementById('next-month-btn');
		const currentMonthDisplay = document.getElementById('current-month-name');

		let currentSlideIndex = 0;
		const totalSlides = slides.length;

		function updateSlider(index: number) {
			currentSlideIndex = index;

			slides.forEach((slide, i) => {
				slide.classList.remove('slide-active', 'slide-inactive', 'slide-left', 'slide-right');
				if (i === index) {
					slide.classList.add('slide-active');
					// Update display text
					if (currentMonthDisplay) {
						currentMonthDisplay.textContent = slide.getAttribute('data-month-label') || '';
					}
				} else if (i < index) {
					slide.classList.add('slide-inactive', 'slide-left');
				} else {
					slide.classList.add('slide-inactive', 'slide-right');
				}
			});

			// Disable buttons at boundaries
			// Remember: index 0 = May (latest), index 1 = Apr, index 2 = Mar
			// Clicking "<" (Prev) should move chronologically back: from 0 -> 1 -> 2
			// Clicking ">" (Next) should move chronologically forward: from 2 -> 1 -> 0
			if (prevBtn) {
				(prevBtn as HTMLButtonElement).disabled = index === totalSlides - 1;
			}
			if (nextBtn) {
				(nextBtn as HTMLButtonElement).disabled = index === 0;
			}
		}

		// Wire up slider arrows
		prevBtn?.addEventListener('click', () => {
			if (currentSlideIndex < totalSlides - 1) {
				updateSlider(currentSlideIndex + 1);
			}
		});

		nextBtn?.addEventListener('click', () => {
			if (currentSlideIndex > 0) {
				updateSlider(currentSlideIndex - 1);
			}
		});

		// Initialize slider state
		updateSlider(0);

		// Calendar Cell & Week Click Filtering
		const activeDays = document.querySelectorAll('.day-chip.day-active');
		const weekFilterBtns = document.querySelectorAll('.btn-filter-week');
		const allCards = document.querySelectorAll('.update-card');
		const clearMonthBtns = document.querySelectorAll('.clear-month-filter-btn');
		
		const filterBanner = document.getElementById('filter-banner');
		const filterDateDisplay = document.getElementById('filter-date-display');
		const clearFilterGlobal = document.getElementById('clear-filter-global');

		// 1. Day Chip Click Filtering
		activeDays.forEach(chip => {
			chip.addEventListener('click', () => {
				const dateStr = chip.getAttribute('data-date');
				const month = chip.getAttribute('data-month');
				if (!dateStr || !month) return;

				const isAlreadySelected = chip.classList.contains('day-selected');
				
				// Deselect other selected days/weeks inside this month
				resetMonthSelections(month);

				if (isAlreadySelected) {
					resetMonthFilters(month);
				} else {
					chip.classList.add('day-selected');
					filterCardsByDate(dateStr, month);
				}
			});
		});

		// 2. Week Filter Button Click Filtering
		weekFilterBtns.forEach(btn => {
			btn.addEventListener('click', () => {
				const weekId = btn.getAttribute('data-week-filter-id');
				const month = btn.getAttribute('data-month');
				const weekCard = btn.closest('.week-row-card');
				if (!weekId || !month || !weekCard) return;

				const isAlreadySelected = weekCard.classList.contains('week-selected');

				// Deselect other selected days/weeks inside this month
				resetMonthSelections(month);

				if (isAlreadySelected) {
					resetMonthFilters(month);
				} else {
					weekCard.classList.add('week-selected');
					filterCardsByWeek(weekId, month);
				}
			});
		});

		// 3. Clear buttons inside month
		clearMonthBtns.forEach(btn => {
			btn.addEventListener('click', () => {
				const month = btn.getAttribute('data-month');
				if (month) resetMonthFilters(month);
			});
		});

		clearFilterGlobal?.addEventListener('click', () => {
			resetAllFilters();
		});

		function resetMonthSelections(month: string) {
			document.querySelectorAll(`.day-chip.day-selected[data-month="${month}"]`).forEach(c => {
				c.classList.remove('day-selected');
			});
			document.querySelectorAll(`.week-row-card.week-selected[data-month="${month}"]`).forEach(w => {
				w.classList.remove('week-selected');
			});
		}

		function filterCardsByDate(dateStr: string, month: string) {
			allCards.forEach(card => {
				const cardDate = card.getAttribute('data-card-date');
				const parentList = card.closest('[data-month-list]');
				const cardMonth = parentList ? parentList.getAttribute('data-month-list') : null;

				if (cardMonth === month) {
					if (cardDate === dateStr) {
						(card as HTMLElement).style.display = 'block';
						card.classList.add('highlighted-card');
					} else {
						(card as HTMLElement).style.display = 'none';
						card.classList.remove('highlighted-card');
					}
				}
			});

			const resetBtn = document.querySelector(`.clear-month-filter-btn[data-month="${month}"]`) as HTMLElement;
			if (resetBtn) resetBtn.style.display = 'inline-block';

			if (filterBanner && filterDateDisplay) {
				const parts = dateStr.split('-');
				const formatted = new Date(Date.UTC(parseInt(parts[0]), parseInt(parts[1]) - 1, parseInt(parts[2]))).toLocaleDateString('en-US', {
					weekday: 'long',
					year: 'numeric',
					month: 'long',
					day: 'numeric',
					timeZone: 'UTC'
				});
				filterDateDisplay.textContent = formatted;
				filterBanner.style.display = 'block';
			}
		}

		function filterCardsByWeek(weekId: string, month: string) {
			const weekCard = document.querySelector(`.week-row-card[data-week-id="${weekId}"]`);
			const weekLabel = weekCard ? weekCard.querySelector('.week-label')?.textContent : '';

			allCards.forEach(card => {
				const cardWeekId = card.getAttribute('data-week-id');
				const parentList = card.closest('[data-month-list]');
				const cardMonth = parentList ? parentList.getAttribute('data-month-list') : null;

				if (cardMonth === month) {
					if (cardWeekId === weekId) {
						(card as HTMLElement).style.display = 'block';
						card.classList.add('highlighted-card');
					} else {
						(card as HTMLElement).style.display = 'none';
						card.classList.remove('highlighted-card');
					}
				}
			});

			const resetBtn = document.querySelector(`.clear-month-filter-btn[data-month="${month}"]`) as HTMLElement;
			if (resetBtn) resetBtn.style.display = 'inline-block';

			if (filterBanner && filterDateDisplay) {
				filterDateDisplay.textContent = weekLabel || 'Selected Week';
				filterBanner.style.display = 'block';
			}
		}

		function resetMonthFilters(month: string) {
			resetMonthSelections(month);

			allCards.forEach(card => {
				const parentList = card.closest('[data-month-list]');
				const cardMonth = parentList ? parentList.getAttribute('data-month-list') : null;
				if (cardMonth === month) {
					(card as HTMLElement).style.display = 'block';
					card.classList.remove('highlighted-card');
				}
			});

			const resetBtn = document.querySelector(`.clear-month-filter-btn[data-month="${month}"]`) as HTMLElement;
			if (resetBtn) resetBtn.style.display = 'none';

			const anySelected = document.querySelectorAll('.day-chip.day-selected, .week-row-card.week-selected').length > 0;
			if (!anySelected && filterBanner) {
				filterBanner.style.display = 'none';
			}
		}

		function resetAllFilters() {
			document.querySelectorAll('.day-chip.day-selected').forEach(c => {
				c.classList.remove('day-selected');
			});
			document.querySelectorAll('.week-row-card.week-selected').forEach(w => {
				w.classList.remove('week-selected');
			});

			allCards.forEach(card => {
				(card as HTMLElement).style.display = 'block';
				card.classList.remove('highlighted-card');
			});

			clearMonthBtns.forEach(btn => {
				(btn as HTMLElement).style.display = 'none';
			});

			if (filterBanner) {
				filterBanner.style.display = 'none';
			}
		}

		// Accordion Collapse/Expand Logic
		const cardHeaders = document.querySelectorAll('.update-card-header-clickable');
		cardHeaders.forEach(header => {
			header.addEventListener('click', () => {
				const card = header.closest('.update-card');
				if (!card) return;
				card.classList.toggle('expanded');
			});
		});
	});
</script>

