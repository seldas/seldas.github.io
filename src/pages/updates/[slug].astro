---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const updates = await getCollection('updates');
	return updates.map(entry => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const dateStr = entry.data.date.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric'
});
---

<Layout title={`${entry.data.title} | Research Update`} description={entry.data.description || `Technical update log for ${entry.data.title}`}>
	<div class="container container-narrow">
		<a href="/updates" class="back-link">
			← Back to Updates
		</a>

		<article class="post-article">
			<header class="post-header">
				<div class="post-meta">
					<time class="post-date">{dateStr}</time>
					{entry.data.project && (
						<span class="badge badge-update">Project: {entry.data.project}</span>
					)}
				</div>
				<h1 class="post-title">{entry.data.title}</h1>
				
				<div class="post-tags">
					{entry.data.tags.map(tag => (
						<span class="badge">{tag}</span>
					))}
				</div>
			</header>

			<hr class="divider" />

			<div class="post-body">
				<Content />
			</div>
		</article>
	</div>
</Layout>

<style>
	.container-narrow {
		max-width: 680px;
		margin: 0 auto;
		padding-bottom: 4rem;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		color: var(--text-muted);
		font-family: var(--font-sans);
		font-size: 0.85rem;
		font-weight: 500;
		text-decoration: none;
		margin-bottom: 2rem;
	}

	.back-link:hover {
		color: var(--accent-color);
		text-decoration: underline;
	}

	.post-header {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin-bottom: 1.5rem;
	}

	.post-meta {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.post-date {
		font-family: var(--font-mono);
		font-size: 0.8rem;
		color: var(--text-muted);
	}

	.post-title {
		font-size: 2rem;
		font-family: var(--font-sans);
		line-height: 1.25;
		color: var(--text-primary);
	}

	.post-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	.divider {
		border: none;
		border-top: 1px solid var(--border-color);
		margin-bottom: 2rem;
	}

	/* Rich Post Body Styles */
	.post-body {
		color: var(--text-primary);
		font-size: 1rem;
		line-height: 1.625;
	}

	.post-body :global(p) {
		margin-bottom: 1.25rem;
	}

	.post-body :global(h2) {
		font-family: var(--font-sans);
		font-size: 1.4rem;
		margin-top: 1.75rem;
		margin-bottom: 0.75rem;
		color: var(--text-primary);
	}

	.post-body :global(h3) {
		font-family: var(--font-sans);
		font-size: 1.15rem;
		margin-top: 1.5rem;
		margin-bottom: 0.5rem;
		color: var(--text-primary);
	}

	.post-body :global(ul), .post-body :global(ol) {
		padding-left: 1.25rem;
		margin-bottom: 1.25rem;
	}

	.post-body :global(li) {
		margin-bottom: 0.35rem;
	}

	.post-body :global(strong) {
		color: var(--text-primary);
	}

	.post-body :global(a) {
		color: var(--accent-color);
		text-decoration: underline;
	}

	.post-body :global(a:hover) {
		color: #002244;
	}

	.post-body :global(code) {
		font-family: var(--font-mono);
		font-size: 0.85em;
		background: #f3f4f6;
		padding: 0.15rem 0.3rem;
		border: 1px solid #e5e7eb;
		border-radius: 2px;
		color: var(--text-primary);
	}

	.post-body :global(pre) {
		font-family: var(--font-mono);
		font-size: 0.85em;
		background: #f8fafc !important;
		border: 1px solid var(--border-color);
		padding: 1rem;
		border-radius: 4px;
		overflow-x: auto;
		margin-bottom: 1.25rem;
	}

	.post-body :global(pre code) {
		background: none;
		border: none;
		padding: 0;
		border-radius: 0;
		color: inherit;
	}
</style>
