---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const updates = await getCollection('updates');

const sortedProjects = projects.sort((a, b) => a.data.order - b.data.order);
const latestUpdates = updates
	.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
	.slice(0, 2);
---

<Layout>
	<div class="container">
		<!-- Hero Section -->
		<section class="hero">
			<h1 class="hero-title">Research Log & Technical Updates</h1>
			<p class="hero-subtitle">
				A repository of machine learning pipelines, gene expression analysis tools, and clinical NLP resources developed by <a href="https://github.com/seldas" target="_blank" rel="noopener noreferrer" class="link-highlight">seldas</a>.
			</p>
			<div class="hero-actions">
				<a href="/projects" class="btn btn-primary">Projects Portfolio</a>
				<a href="/updates" class="btn btn-secondary">Updates Timeline</a>
			</div>
		</section>

		<!-- Research Focus Areas -->
		<section class="section">
			<h2 class="section-title">Research Focus Areas</h2>
			<div class="grid">
				<div class="card focus-card">
					<div class="focus-icon">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
					</div>
					<h3>Clinical NLP & Regulatory Intelligence</h3>
					<p>Developing automated pipelines to parse Structured Product Labeling (SPL) files, compare warnings, and extract adverse event indicators from regulatory documents.</p>
				</div>
				<div class="card focus-card">
					<div class="focus-icon">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 3.5-2 3.5s2.24-.5 3.5-2c1.26-1.5 3.5-2 3.5-2s-2.24.5-3.5 2z"></path><path d="M9.5 11.5c-1.5 1.26-2 3.5-2 3.5s2.24-.5 3.5-2c1.26-1.5 3.5-2 3.5-2s-2.24.5-3.5 2z"></path><path d="M5.5 12.5c-1.5 1.26-2 3.5-2 3.5s2.24-.5 3.5-2c1.26-1.5 3.5-2 3.5-2s-2.24.5-3.5 2z"></path><path d="M11.5 9.5c-1.5 1.26-2 3.5-2 3.5s2.24-.5 3.5-2c1.26-1.5 3.5-2 3.5-2s-2.24.5-3.5 2z"></path><path d="M8.5 7.5c-1.5 1.26-2 3.5-2 3.5s2.24-.5 3.5-2c1.26-1.5 3.5-2 3.5-2s-2.24.5-3.5 2z"></path><path d="M14.5 4.5c-1.5 1.26-2 3.5-2 3.5s2.24-.5 3.5-2c1.26-1.5 3.5-2 3.5-2s-2.24.5-3.5 2z"></path></svg>
					</div>
					<h3>Deep Learning & Bioinformatics</h3>
					<p>Training neural autoencoder architectures to encode high-dimensional gene expression profiles and map biological phenotypes in cancer genomic studies.</p>
				</div>
			</div>
		</section>

		<!-- Featured Projects -->
		<section class="section">
			<div class="section-header">
				<h2 class="section-title">Featured Projects</h2>
				<a href="/projects" class="section-link">All Projects →</a>
			</div>
			<div class="grid">
				{sortedProjects.map(project => (
					<div class="card project-card">
						<div class="project-header">
							<span class={`badge ${project.data.status === 'Active' ? 'badge-active' : ''}`}>{project.data.status}</span>
							<a href={project.data.github} target="_blank" rel="noopener noreferrer" class="project-git-link" aria-label="GitHub repo">
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
							</a>
						</div>
						<h3>{project.data.title}</h3>
						<p>{project.data.description}</p>
						<div class="project-tags">
							{project.data.tags.map(tag => (
								<span class="badge">{tag}</span>
							))}
						</div>
					</div>
				))}
			</div>
		</section>

		<!-- Latest Updates Log -->
		<section class="section">
			<div class="section-header">
				<h2 class="section-title">Latest Updates</h2>
				<a href="/updates" class="section-link">Full Timeline →</a>
			</div>
			<div class="updates-list">
				{latestUpdates.map(update => (
					<div class="update-preview-card">
						<div class="update-meta">
							<span class="update-date">{update.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
							{update.data.project && (
								<span class="badge badge-update">{update.data.project}</span>
							)}
						</div>
						<h3 class="update-title">
							<a href={`/updates/${update.id}`}>{update.data.title}</a>
						</h3>
						{update.data.description && <p class="update-desc">{update.data.description}</p>}
						<a href={`/updates/${update.id}`} class="update-readmore">Read Log Entry →</a>
					</div>
				))}
			</div>
		</section>
	</div>
</Layout>

<style>
	/* Hero Section */
	.hero {
		padding: 3rem 0;
		max-width: 720px;
	}
	.hero-title {
		font-size: 2.2rem;
		font-family: var(--font-sans);
		font-weight: 600;
		color: var(--text-primary);
		margin-bottom: 1rem;
		letter-spacing: -0.01em;
	}
	.hero-subtitle {
		font-size: 1.1rem;
		color: var(--text-secondary);
		line-height: 1.6;
		margin-bottom: 2rem;
	}
	.link-highlight {
		color: var(--accent-color);
		font-weight: 500;
		text-decoration: underline;
	}
	.hero-actions {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	/* Sections */
	.section {
		padding: 3rem 0 1.5rem;
	}
	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		margin-bottom: 1.5rem;
		border-bottom: 1px solid var(--border-color);
		padding-bottom: 0.5rem;
	}
	.section-title {
		font-size: 1.5rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		margin: 0;
	}
	.section-link {
		font-size: 0.875rem;
		color: var(--accent-color);
		font-family: var(--font-sans);
		font-weight: 500;
		text-decoration: none;
	}
	.section-link:hover {
		text-decoration: underline;
	}

	/* Focus Cards */
	.focus-card {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}
	.focus-icon {
		width: 36px;
		height: 36px;
		border: 1px solid var(--border-color);
		border-radius: 4px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--text-secondary);
		background: #fafafa;
	}
	.focus-card h3 {
		font-size: 1.15rem;
		margin: 0;
	}
	.focus-card p {
		color: var(--text-secondary);
		line-height: 1.5;
		font-size: 0.9rem;
	}

	/* Project Card specific */
	.project-card {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.project-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.project-git-link {
		color: var(--text-muted);
	}
	.project-git-link:hover {
		color: var(--accent-color);
	}
	.project-card h3 {
		font-size: 1.25rem;
		margin: 0;
	}
	.project-card p {
		color: var(--text-secondary);
		font-size: 0.9rem;
		line-height: 1.5;
		flex-grow: 1;
	}
	.project-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-top: 0.5rem;
	}

	/* Updates List styling */
	.updates-list {
		display: flex;
		flex-direction: column;
	}
	.update-preview-card {
		border-bottom: 1px solid var(--border-color);
		padding: 1.5rem 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.update-preview-card:last-child {
		border-bottom: none;
	}
	.update-meta {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}
	.update-date {
		font-size: 0.8rem;
		font-family: var(--font-mono);
		color: var(--text-muted);
	}
	.update-title {
		font-size: 1.2rem;
		margin: 0;
		font-family: var(--font-sans);
	}
	.update-title a {
		text-decoration: none;
		color: var(--text-primary);
	}
	.update-title a:hover {
		color: var(--accent-color);
		text-decoration: underline;
	}
	.update-desc {
		color: var(--text-secondary);
		font-size: 0.9rem;
		line-height: 1.5;
	}
	.update-readmore {
		font-size: 0.85rem;
		font-family: var(--font-sans);
		font-weight: 500;
		color: var(--accent-color);
		text-decoration: none;
	}
	.update-readmore:hover {
		text-decoration: underline;
	}
</style>
