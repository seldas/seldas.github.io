---
import Layout from '../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

const rawPublications = await getCollection('researches');

// Filter out English versions from the main list
const mainPublications = rawPublications.filter(pub => !pub.id.endsWith('-en'));

// Sort publications chronologically: latest first
const sortedPublications = mainPublications.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Render summaries for all publications
const publications = await Promise.all(
	sortedPublications.map(async (pub) => {
		const { Content } = await render(pub);
		
		// Find English counterpart
		const enPub = rawPublications.find(p => p.id === `${pub.id}-en`);
		let ContentEn = null;
		let enHighlights: string[] = [];
		if (enPub) {
			const renderedEn = await render(enPub);
			ContentEn = renderedEn.Content;
			enHighlights = enPub.data.highlights || [];
		}

		return {
			id: pub.id,
			title: pub.data.title,
			academicTitle: pub.data.academicTitle,
			journal: pub.data.journal,
			date: pub.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', timeZone: 'UTC' }),
			isoDate: pub.data.date.toISOString().split('T')[0],
			authors: pub.data.authors,
			doi: pub.data.doi,
			doiUrl: pub.data.doiUrl,
			pdfUrl: pub.data.pdfUrl,
			pdfSize: pub.data.pdfSize,
			highlights: pub.data.highlights,
			Content,
			ContentEn,
			enHighlights,
		};
	})
);
---

<Layout title="Research Publications | seldas" description="Academic publications, clinical safety NLP models, and Structured Product Labeling (SPL) research.">
	<div class="container container-wide">
		<header class="page-header">
			<h1 class="page-title">Research Publications</h1>
			<p class="page-subtitle">Scientific papers and NLP frameworks developed for regulatory environments and clinical safety.</p>
		</header>

		<!-- Mobile TOC Dropdown Selector -->
		<div class="mobile-toc-container">
			<button id="mobile-toc-trigger" class="btn btn-secondary btn-full">
				<span>Jump to Article...</span>
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="chevron-icon"><polyline points="6 9 12 15 18 9"></polyline></svg>
			</button>
			<div id="mobile-toc-dropdown" class="mobile-toc-dropdown">
				{publications.map(pub => (
					<a href={`#${pub.id}`} class="mobile-toc-link" data-target-id={pub.id} key={pub.id}>
						{pub.title}
					</a>
				))}
			</div>
		</div>

		<!-- Two-column Blog Grid Layout -->
		<div class="research-layout-grid">
			<!-- Main Blog Posts List (Only one card visible at a time) -->
			<main class="research-main-content">
				<div class="publications-list">
					{publications.map((pub, index) => {
						const { Content } = pub;
						return (
							<article class="blog-post-card" id={pub.id} key={pub.doi} style="display: none;">
								<div class="paper-header">
									<div class="paper-meta">
										{pub.journal && <span class="journal-tag">{pub.journal}</span>}
										<span class="pub-date">{pub.date}</span>
									</div>
									<h2 class="paper-display-title">
										{pub.title}
									</h2>
									{pub.academicTitle && (
										<p class="paper-academic-title">
											<strong>Original Title:</strong> <span class="title-italic">{pub.academicTitle}</span>
										</p>
									)}
									{(pub.authors || pub.doi) && (
										<p class="paper-authors">
											{pub.authors && <span>{pub.authors}</span>}
											{pub.doi && <span> | <span class="doi">DOI: {pub.doi}</span></span>}
										</p>
									)}
								</div>

								<div class={['2024-04-02-askfdalabel-framework', '2025-02-20-ae-classification'].includes(pub.id) ? "paper-grid" : "paper-single-column"}>
									<div class="paper-summary-column">
										<h3 class="column-title">Plain Language Summary</h3>
										{pub.ContentEn && (
											<div class="lang-switcher-container" style="display: flex; justify-content: flex-end; margin-bottom: 1rem;">
												<div class="btn-group" style="display: flex; gap: 0.5rem;" role="group" aria-label="Language Switcher">
													<button type="button" class="btn btn-sm btn-secondary lang-btn" data-target={pub.id} data-lang="zh" style="opacity: 0.6; border: 1px solid var(--border-color);">中文</button>
													<button type="button" class="btn btn-sm btn-secondary lang-btn active" data-target={pub.id} data-lang="en" style="opacity: 1; border: 1px solid var(--border-color);">English</button>
												</div>
											</div>
										)}
										<div class={`plain-text-body content-zh-${pub.id}`} style={pub.ContentEn ? "display: none;" : ""}>
											<Content />
											
											{pub.highlights && pub.highlights.length > 0 && (
												<>
													<h4 class="highlights-title">核心记录 / Key Highlights:</h4>
													<ul class="highlights-list">
														{pub.highlights.map(hl => (
															<li set:html={hl}></li>
														))}
													</ul>
												</>
											)}
										</div>

										{pub.ContentEn && (
											<div class={`plain-text-body content-en-${pub.id}`} style="display: block;">
												{(() => { const ContentEn = pub.ContentEn; return <ContentEn /> })()}
												
												{pub.enHighlights && pub.enHighlights.length > 0 && (
													<>
														<h4 class="highlights-title">Key Highlights:</h4>
														<ul class="highlights-list">
															{pub.enHighlights.map(hl => (
																<li set:html={hl}></li>
															))}
														</ul>
													</>
												)}
											</div>
										)}
									</div>

									{['2024-04-02-askfdalabel-framework', '2025-02-20-ae-classification'].includes(pub.id) && (
										<div class="paper-side-column">
										{pub.id === "2024-04-02-askfdalabel-framework" && (
											<div class="architecture-card">
												<h4>AskFDALabel Flow</h4>
												<p>Splits the regulatory query pipeline into two secure modules:</p>
												<div class="arch-flow">
													<div class="arch-step">
														<strong>Module S: Semantic Search</strong>
														<span>Converts drug labels into word vectors to query and pull relevant warning text.</span>
													</div>
													<div class="arch-arrow">&darr;</div>
													<div class="arch-step">
														<strong>Module T: Text Generation</strong>
														<span>Summarizes the extracted text using a secure, local LLM to generate the final response.</span>
													</div>
												</div>
											</div>
										)}
										
										{pub.id === "2025-02-20-ae-classification" && (
											<div class="architecture-card">
												<h4>Safety Benchmarks</h4>
												<p>Evaluation results demonstrating model performance:</p>
												<div class="arch-flow">
													<div class="arch-step">
														<strong>Liver Injury (DILI)</strong>
														<span>Classifies DILI risk with an outstanding F1-score of <strong>0.978</strong>.</span>
													</div>
													<div class="arch-step">
														<strong>Cardiotoxicity (DICT)</strong>
														<span>Detects DICT risk signals with an F1-score of <strong>0.931</strong>.</span>
													</div>
												</div>
											</div>
										)}
									</div>
									)}
								</div>

								<!-- Action Buttons in Card Footer -->
								<div class="post-footer-actions">
									{pub.pdfUrl && (
										<a href={pub.pdfUrl} download class="btn btn-primary btn-sm">
											<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="btn-icon"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
											Download PDF ({pub.pdfSize})
										</a>
									)}
									
									{pub.doiUrl && (
										<a href={pub.doiUrl} target="_blank" rel="noopener noreferrer" class="btn btn-secondary btn-sm">
											<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="btn-icon"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
											View Publisher Journal
										</a>
									)}
								</div>
							</article>
						);
					})}
				</div>
			</main>

			<!-- Sticky Right Sidebar with Table of Contents (Scrollable if > 50 items) -->
			<aside class="research-sidebar">
				<div class="sidebar-sticky-box">
					<h3 class="sidebar-title">Research Archive</h3>
					<div class="calendar-widget">
						<div class="calendar-header">
							<button id="cal-prev" class="cal-btn" aria-label="Previous Month">&lt;</button>
							<div id="cal-month-year" class="cal-title"></div>
							<button id="cal-next" class="cal-btn" aria-label="Next Month">&gt;</button>
						</div>
						<div class="calendar-days-header">
							<span>Su</span><span>Mo</span><span>Tu</span><span>We</span><span>Th</span><span>Fr</span><span>Sa</span>
						</div>
						<div id="calendar-grid" class="calendar-grid"></div>
						<div id="calendar-posts-list" class="calendar-posts-list"></div>
					</div>
					
					<div class="sidebar-extra-info">
						<h4>Research Context</h4>
						<p>These plain-language reviews focus on integrating Large Language Models safely into highly regulated environments like pharmacovigilance and drug label compliance.</p>
					</div>
				</div>
			</aside>
		</div>
	</div>
</Layout>

<script is:inline define:vars={{ publicationsData: publications.map(p => ({ id: p.id, isoDate: p.isoDate, title: p.title })) }}>
	window.publicationsData = publicationsData;
</script>
<script>
	// Doc-reader View Manager Script
	document.addEventListener('DOMContentLoaded', () => {
		const articles = document.querySelectorAll('.blog-post-card');
		const mobileLinks = document.querySelectorAll('.mobile-toc-link');
		const mobileTrigger = document.getElementById('mobile-toc-trigger');
		const mobileDropdown = document.getElementById('mobile-toc-dropdown');
		const mobileTriggerText = mobileTrigger?.querySelector('span');
		const langBtns = document.querySelectorAll('.lang-btn');

		if (articles.length === 0) return;

		// --- Calendar Logic ---
		const pubData = window.publicationsData || [];
		const dateMap = {};
		pubData.forEach(p => {
			if (!dateMap[p.isoDate]) dateMap[p.isoDate] = [];
			dateMap[p.isoDate].push(p);
		});

		const calMonthYear = document.getElementById('cal-month-year');
		const calGrid = document.getElementById('calendar-grid');
		const calPostsList = document.getElementById('calendar-posts-list');
		const btnPrev = document.getElementById('cal-prev');
		const btnNext = document.getElementById('cal-next');

		const allDates = Object.keys(dateMap).sort();
		const availableMonths = [...new Set(allDates.map(d => d.substring(0, 7)))].sort(); // e.g. ["2024-04", "2025-02", "2026-05"]
		
		let currentDisplayDate = new Date();
		if (allDates.length > 0) {
			const latestDate = new Date(allDates[allDates.length - 1] + "T00:00:00");
			currentDisplayDate = new Date(latestDate.getFullYear(), latestDate.getMonth(), 1);
		} else {
			currentDisplayDate = new Date(currentDisplayDate.getFullYear(), currentDisplayDate.getMonth(), 1);
		}

		let activePostId = null;

		function renderCalendar(date) {
			if (!calGrid || !calMonthYear) return;
			const year = date.getFullYear();
			const month = date.getMonth();
			
			const monthNames = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
			calMonthYear.textContent = `${monthNames[month]} ${year}`;
			calGrid.innerHTML = '';
			calPostsList.innerHTML = '';

			const firstDay = new Date(year, month, 1).getDay();
			const daysInMonth = new Date(year, month + 1, 0).getDate();

			for (let i = 0; i < firstDay; i++) {
				const emptyCell = document.createElement('div');
				emptyCell.className = 'cal-day empty';
				calGrid.appendChild(emptyCell);
			}

			for (let i = 1; i <= daysInMonth; i++) {
				const cell = document.createElement('div');
				cell.className = 'cal-day';
				cell.textContent = i;
				
				const isoStr = `${year}-${String(month+1).padStart(2, '0')}-${String(i).padStart(2, '0')}`;
				const postsOnDay = dateMap[isoStr];

				if (postsOnDay && postsOnDay.length > 0) {
					cell.classList.add('has-post');
					
					if (activePostId && postsOnDay.some(p => p.id === activePostId)) {
						cell.classList.add('active-post');
					}

					cell.addEventListener('click', () => {
						document.querySelectorAll('.cal-day').forEach(c => c.classList.remove('active-post'));
						cell.classList.add('active-post');

						calPostsList.innerHTML = '';
						if (postsOnDay.length === 1) {
							const targetId = postsOnDay[0].id;
							history.pushState(null, '', `#${targetId}`);
							showArticle(targetId);
						} else {
							postsOnDay.forEach(p => {
								const link = document.createElement('a');
								link.className = 'cal-post-link';
								link.href = `#${p.id}`;
								link.textContent = p.title.split(':')[0];
								link.addEventListener('click', (e) => {
									e.preventDefault();
									history.pushState(null, '', `#${p.id}`);
									showArticle(p.id);
								});
								calPostsList.appendChild(link);
							});
						}
					});
				}
				calGrid.appendChild(cell);
			}

			// Update button states based on available months
			const currentMonthStr = `${year}-${String(month+1).padStart(2, '0')}`;
			if (btnPrev) {
				const hasPrev = availableMonths.some(m => m < currentMonthStr);
				btnPrev.style.opacity = hasPrev ? '1' : '0.3';
				btnPrev.style.pointerEvents = hasPrev ? 'auto' : 'none';
			}
			if (btnNext) {
				const hasNext = availableMonths.some(m => m > currentMonthStr);
				btnNext.style.opacity = hasNext ? '1' : '0.3';
				btnNext.style.pointerEvents = hasNext ? 'auto' : 'none';
			}
		}

		if (btnPrev) {
			btnPrev.addEventListener('click', () => {
				const year = currentDisplayDate.getFullYear();
				const month = currentDisplayDate.getMonth();
				const currentMonthStr = `${year}-${String(month+1).padStart(2, '0')}`;
				
				// Find largest month smaller than current
				const prevMonths = availableMonths.filter(m => m < currentMonthStr);
				if (prevMonths.length > 0) {
					const targetMonthStr = prevMonths[prevMonths.length - 1]; // e.g., "2025-02"
					const parts = targetMonthStr.split('-');
					currentDisplayDate = new Date(parseInt(parts[0]), parseInt(parts[1]) - 1, 1);
					renderCalendar(currentDisplayDate);
				}
			});
		}
		if (btnNext) {
			btnNext.addEventListener('click', () => {
				const year = currentDisplayDate.getFullYear();
				const month = currentDisplayDate.getMonth();
				const currentMonthStr = `${year}-${String(month+1).padStart(2, '0')}`;
				
				// Find smallest month larger than current
				const nextMonths = availableMonths.filter(m => m > currentMonthStr);
				if (nextMonths.length > 0) {
					const targetMonthStr = nextMonths[0]; // e.g., "2026-05"
					const parts = targetMonthStr.split('-');
					currentDisplayDate = new Date(parseInt(parts[0]), parseInt(parts[1]) - 1, 1);
					renderCalendar(currentDisplayDate);
				}
			});
		}

		function updateCalendarActiveState(targetId) {
			activePostId = targetId;
			let targetDate = null;
			for (const [dateStr, posts] of Object.entries(dateMap)) {
				if (posts.some(p => p.id === targetId)) {
					targetDate = new Date(dateStr + "T00:00:00");
					break;
				}
			}
			if (targetDate) {
				if (targetDate.getFullYear() !== currentDisplayDate.getFullYear() || targetDate.getMonth() !== currentDisplayDate.getMonth()) {
					currentDisplayDate = new Date(targetDate.getFullYear(), targetDate.getMonth(), 1);
				}
			}
			renderCalendar(currentDisplayDate);
		}
		// --- End Calendar Logic ---

		// Language Switcher Logic
		langBtns.forEach(btn => {
			btn.addEventListener('click', (e) => {
				const target = e.currentTarget;
				const id = target.getAttribute('data-target');
				const lang = target.getAttribute('data-lang');
				
				document.querySelectorAll(`.lang-btn[data-target="${id}"]`).forEach(b => {
					b.classList.remove('active');
					b.style.opacity = '0.6';
				});
				target.classList.add('active');
				target.style.opacity = '1';

				const zhContent = document.querySelector(`.content-zh-${id}`);
				const enContent = document.querySelector(`.content-en-${id}`);
				
				if (zhContent && enContent) {
					if (lang === 'en') {
						zhContent.style.display = 'none';
						enContent.style.display = 'block';
					} else {
						zhContent.style.display = 'block';
						enContent.style.display = 'none';
					}
				}
			});
		});

		function showArticle(targetId) {
			const targetArticle = document.getElementById(targetId);
			if (!targetArticle) return;

			articles.forEach(article => {
				article.style.display = 'none';
				article.classList.remove('active');
			});

			targetArticle.style.display = 'block';
			targetArticle.classList.add('active');

			updateCalendarActiveState(targetId);

			mobileLinks.forEach(link => {
				const target = link.getAttribute('data-target-id');
				if (target === targetId) {
					link.classList.add('active');
					if (mobileTriggerText) {
						mobileTriggerText.textContent = link.textContent.trim() || 'Select Article...';
					}
				} else {
					link.classList.remove('active');
				}
			});

			window.scrollTo({ top: 0, behavior: 'smooth' });
		}

		// Wire up Mobile TOC Dropdown Trigger
		mobileTrigger?.addEventListener('click', (e) => {
			e.stopPropagation();
			mobileDropdown?.classList.toggle('show');
			mobileTrigger.classList.toggle('active');
		});

		// Wire up Mobile Dropdown Link Clicks
		mobileLinks.forEach(link => {
			link.addEventListener('click', (e) => {
				e.preventDefault();
				const targetId = link.getAttribute('data-target-id');
				if (targetId) {
					history.pushState(null, '', `#${targetId}`);
					showArticle(targetId);
					mobileDropdown?.classList.remove('show');
					mobileTrigger?.classList.remove('active');
				}
			});
		});

		// Close mobile dropdown when clicking outside
		document.addEventListener('click', () => {
			mobileDropdown?.classList.remove('show');
			mobileTrigger?.classList.remove('active');
		});

		// Check URL hash on initial page load
		const initialHash = window.location.hash.substring(1);
		if (initialHash && document.getElementById(initialHash)) {
			showArticle(initialHash);
		} else {
			// Show the first article by default
			const firstId = articles[0].getAttribute('id');
			if (firstId) showArticle(firstId);
		}

		// Handle browser Back/Forward navigation changes
		window.addEventListener('hashchange', () => {
			const hash = window.location.hash.substring(1);
			if (hash && document.getElementById(hash)) {
				showArticle(hash);
			} else if (!hash) {
				// Fallback to first article if hash is cleared
				const firstId = articles[0].getAttribute('id');
				if (firstId) showArticle(firstId);
			}
		});
	});
</script>

<style>
	.container-wide {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	.page-header {
		margin-bottom: 2rem;
		border-bottom: 1px solid var(--border-color);
		padding-bottom: 1.5rem;
	}
	.page-title {
		font-size: 2.2rem;
		font-family: var(--font-sans);
		margin-bottom: 0.5rem;
		font-weight: 600;
		color: var(--text-primary);
	}
	.page-subtitle {
		font-size: 1.1rem;
		color: var(--text-secondary);
		line-height: 1.5;
	}

	/* Mobile TOC Dropdown container */
	.mobile-toc-container {
		display: block;
		margin-bottom: 2rem;
		position: relative;
		z-index: 10;
	}

	@media (min-width: 960px) {
		.mobile-toc-container {
			display: none;
		}
	}

	.mobile-toc-dropdown {
		display: none;
		position: absolute;
		top: 100%;
		left: 0;
		right: 0;
		background: #ffffff;
		border: 1px solid var(--border-color);
		border-radius: 4px;
		margin-top: 0.5rem;
		box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
		max-height: 280px;
		overflow-y: auto;
		z-index: 20;
	}

	.mobile-toc-dropdown.show {
		display: block;
	}

	.mobile-toc-link {
		display: block;
		padding: 0.75rem 1rem;
		font-family: var(--font-sans);
		font-size: 0.85rem;
		color: var(--text-secondary);
		text-decoration: none;
		border-bottom: 1px solid #f3f4f6;
		transition: background-color var(--transition-speed);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.mobile-toc-link:last-child {
		border-bottom: none;
	}

	.mobile-toc-link:hover, .mobile-toc-link.active {
		background: #f8fafc;
		color: var(--accent-color);
		font-weight: 600;
	}
	
	#mobile-toc-trigger {
		display: flex;
		align-items: center;
		justify-content: space-between;
		font-family: var(--font-sans);
		font-size: 0.9rem;
		padding: 0.6rem 1rem;
		background: #ffffff;
		border: 1px solid var(--border-color);
		border-radius: 4px;
	}

	#mobile-toc-trigger span {
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		padding-right: 1rem;
	}
	
	#mobile-toc-trigger.active .chevron-icon {
		transform: rotate(180deg);
	}
	
	.chevron-icon {
		transition: transform 0.2s ease;
		flex-shrink: 0;
	}

	/* Two-column Blog Layout Grid */
	.research-layout-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2.5rem;
		margin-bottom: 5rem;
	}

	@media (min-width: 960px) {
		.research-layout-grid {
			grid-template-columns: 1fr 280px;
		}
	}

	.research-main-content {
		min-width: 0;
