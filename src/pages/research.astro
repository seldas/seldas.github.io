---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Research | seldas" description="Long-form research articles, literature reviews, and clinical safety publications.">
	<div class="container">
		<header class="page-header">
			<h1 class="page-title">Research Articles</h1>
			<p class="page-subtitle">Long-form articles, literature reviews, and systematic publications in Clinical NLP and Bioinformatics.</p>
		</header>

		<div class="placeholder-box">
			<p>This section is under construction. Comprehensive research articles, methodology papers, and literature guides will be hosted here soon.</p>
		</div>
	</div>
</Layout>

<style>
	.page-header {
		margin-bottom: 3rem;
		border-bottom: 1px solid var(--border-color);
		padding-bottom: 1.5rem;
	}
	.page-title {
		font-size: 2.2rem;
		font-family: var(--font-sans);
		margin-bottom: 0.5rem;
		font-weight: 600;
	}
	.page-subtitle {
		font-size: 1.1rem;
		color: var(--text-secondary);
		line-height: 1.5;
	}
	.placeholder-box {
		border: 1px dashed var(--border-color);
		padding: 4rem 2rem;
		text-align: center;
		color: var(--text-secondary);
		font-style: italic;
		border-radius: 4px;
		background: #fafafa;
		font-size: 1.05rem;
	}
</style>
